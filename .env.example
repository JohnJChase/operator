# Copy to .env only when a phase needs these values.
# Do not commit .env.

# Phase 5+: news refresh (weather/Open-Meteo needs no key).
NEWSDATA_API_KEY=

# Phase 7+: Realtime information operator (digit 8).
OPENAI_API_KEY=

# Phase 9+: Telnyx SIP outside line (digit 9).
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=
TELNYX_SIP_USER=
TELNYX_SIP_PASSWORD=
# Optional E.164 caller ID (Telnyx number on the connection). Required for outbound.
TELNYX_CALLER_ID=

# Optional future local diagnostics console.
OPERATOR_CONSOLE_PASSWORD=
