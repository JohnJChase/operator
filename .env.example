# Copy to .env — do not commit .env.

# News refresh (weather/Open-Meteo needs no key).
NEWSDATA_API_KEY=

# Info desk (digit 8): STT + tool LLM. Piper is local.
OPENAI_API_KEY=

# Telnyx SIP outside line (digit 9) + inbound DID.
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=
TELNYX_SIP_USER=
TELNYX_SIP_PASSWORD=
# E.164 caller ID (Telnyx number on the connection). Required for outbound.
TELNYX_CALLER_ID=

# SMS (Block 4). From defaults to TELNYX_CALLER_ID if unset.
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_SMS_FROM=
# Mission Control → Keys & Credentials → Public Key (ed25519 verify).
# If unset, local webhook accepts unsigned POSTs (sms-inject / Funnel without verify).
TELNYX_PUBLIC_KEY=
OPERATOR_SMS_WEBHOOK_PORT=8787

# Google Calendar / Meet dial-in (digit 7). Fill Client ID+secret from Cloud
# Console; refresh token from `just calendar-auth` (Block 3).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
# Optional: comma-separated calendar ids. Default = primary + calendars you own & selected.
# (Does not scan coworkers' shared calendars.)
# GOOGLE_CALENDAR_IDS=primary,someone@group.calendar.google.com
# GOOGLE_CALENDAR_ID=primary

# Optional future local diagnostics console.
OPERATOR_CONSOLE_PASSWORD=
